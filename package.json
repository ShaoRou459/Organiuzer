{
  "name": "organiuzer",
  "version": "1.0.2",
  "description": "AI-powered desktop folder organizer with review, history, and safe move execution.",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --strictPort\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win nsis",
    "dist:x64": "npm run build && electron-builder --win nsis --x64",
    "dist:arm64": "npm run build && electron-builder --win nsis --arm64"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.4",
    "electron-builder": "^25.1.8",
    "vite": "^7.2.6",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.organiuzer.app",
    "productName": "Organiuzer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@material/material-color-utilities": "^0.3.0",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "electron-store": "^11.0.2",
    "framer-motion": "^12.23.25",
    "fs-extra": "^11.3.2",
    "glob": "^13.0.0",
    "openai": "^6.9.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.6.0"
  }
}
